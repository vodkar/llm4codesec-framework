    "experiment_plans": {
        "quick_test": {
            "description": "Quick test with limited samples for binary classification development",
            "datasets": [
                "binary_c_file",
                "binary_java_file",
                "binary_python_file"
            ],
            "models": [
                "qwen3-4b",
                "llama3.2-3B",
                "gemma3-4b",
                "deepseek-r1-distill-qwen2.5-7b"
            ],
            "prompts": [
                "step_by_step"
            ],
            "sample_limit": 10
        },
        "llama_cpp_evaluation": {
            "description": "llama.cpp backend evaluation using Qwen3-8B GGUF quantizations",
            "datasets": [
                "binary_c_file"
            ],
            "models": [
                "qwen3-8b-gguf",
                "qwen3-8b-gguf-q8"
            ],
            "prompts": [
                "step_by_step"
            ],
            "sample_limit": 3
        },
